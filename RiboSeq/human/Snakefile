        filtered_readLen_s = expand(stats_data + '{sample_uniq}_filtered_readLenDist.dat', sample_uniq=uniq_SAMPLES),
        dedup_s = expand(stats_data + '{sample_uniq}' + '_dedup.dat', sample_uniq=uniq_SAMPLES),
